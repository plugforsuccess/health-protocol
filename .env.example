VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Web Push — public VAPID key (safe to expose in the client bundle).
# Generate a pair with `npx web-push generate-vapid-keys` and paste the
# PUBLIC key here; store the PRIVATE key as a Supabase Edge Function
# secret (see README). Leave blank to disable Web Push entirely.
VITE_VAPID_PUBLIC_KEY=
